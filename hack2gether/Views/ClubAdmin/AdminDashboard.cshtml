@{
    ViewData["Title"] = "Club Admin Dashboard";
}

<style>
    body {
        background-color: #00447b;
        color: #00447b;
        font-family: Arial, sans-serif;
    }

    .card {
        background-color: #ffffff;
        color: #000000;
        border-radius: 10px;
    }

    .section-title {
        font-weight: bold;
        margin-bottom: 0.5rem;
    }

    .task-card {
        border-radius: 10px;
        padding: 1.25rem;
        margin-bottom: 1rem;
        background-color: #f5f5f5;
    }

        .task-card h5 {
            margin-bottom: 0.5rem;
        }
</style>

<div class="text-center mt-4 mb-4">
    <h1 class="display-5">Club Admin Dashboard</h1>
    <p>Student officers + faculty advisors • Create events • Run check-in • Manage club presence</p>
</div>

<div class="container">
    <div class="row">
        <!--Buttons here don't work yet-->

        <!-- Student officers + faculty advisors -->
        <div class="col-md-6 mb-3">
            <div class="task-card">
                <h5>Student Officers & Faculty Advisors</h5>
                <p>View and manage your club’s leadership team.</p>
                <a asp-controller="ClubAdmin" asp-action="Officers" class="btn btn-success">
                    Manage Officers & Advisors
                </a>
            </div>
        </div>

        <!-- Create events -->
        <div class="col-md-6 mb-3">
            <div class="task-card">
                <h5>Create Events</h5>
                <p>Set up new events for your club, including date, time, and location.</p>
                <a asp-controller="ClubAdmin" asp-action="CreateEvent" class="btn btn-success">
                    Create New Event
                </a>
            </div>
        </div>

        <!-- Run check-in -->
        <div class="col-md-6 mb-3">
            <div class="task-card">
                <h5>Run Check-In</h5>
                <p>Open an event and track who attends in real time.</p>
                <a asp-controller="ClubAdmin" asp-action="CheckIn" class="btn btn-success">
                    Run Check-In
                </a>
            </div>
        </div>

        <!-- Manage club presence -->
        <div class="col-md-6 mb-3">
            <div class="task-card">
                <h5>Manage Club Presence</h5>
                <p>Review attendance history and overall engagement for your club.</p>
                <a asp-controller="ClubAdmin" asp-action="Presence" class="btn btn-success">
                    View Club Presence
                </a>
            </div>
        </div>

    </div>
</div>