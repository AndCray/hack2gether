@using hack2gether.Models
@model hack2gether.Models.EngagementDashboardViewModel

@{
    ViewData["Title"] = "Engagement Staff Dashboard";
}

<style>
    body {
        background-color: #00447b;
        color: #ffffff;
        font-family: Arial, sans-serif;
    }

    .section-card {
        background: #ffffff;
        color: #000;
        padding: 1.25rem;
        border-radius: 10px;
        margin-bottom: 2rem;
    }

    h3 {
        margin-bottom: 1rem;
    }

    table {
        background: #fff;
    }
</style>

<!--Page doesn't load yet due to some error when loading the user login for Engagement Staff, 
which leads to the other pages in this folder to not work-->

<div class="text-center mt-4 mb-4">
    <h1 class="display-5">Engagement Staff Command Center</h1>
    <p>Approve events • Route notifications • Campus at a glance</p>
</div>

<div class="container">

    <!-- APPROVE EVENTS SECTION -->
    @* 
        <!-- preserved original commented block (converted to Razor comment to avoid mixed HTML/Razor parsing issues) -->
        <div class="section-card">
            <h3>Approve Events</h3>

            @if (Model?.PendingEvents == null || !Model.PendingEvents.Any())
            {
                <p>No pending events.</p>
            }
            else
            {
                <table class="table table-bordered table-light">
                    <thead>
                        <tr>
                            <th>Event</th>
                            <th>Date</th>
                            <th>Club</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var evt in Model.PendingEvents)
                        {
                            <tr>
                                <td>@evt.Title</td>
                                <td>@evt.Date.ToShortDateString()</td>
                                <td>@evt.ClubName</td>
                                <td>
                                    <button class="btn btn-success btn-sm">Approve</button>
                                    <button class="btn btn-danger btn-sm">Reject</button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </div>
    *@

    <!-- NOTIFICATIONS SECTION -->
    <div class="section-card">
        <h3>Route Notifications</h3>

        <form>
            <div class="form-group mb-3">
                <label>Department</label>
                <select class="form-control">
                    <option>Student Life</option>
                    <option>Security</option>
                    <option>Facilities</option>
                    <option>IT</option>
                </select>
            </div>

            <div class="form-group mb-3">
                <label>Message</label>
                <textarea class="form-control" rows="4"></textarea>
            </div>

            <button class="btn btn-primary">Send Notification</button>
        </form>
    </div>

    <!-- CAMPUS OVERVIEW SECTION -->
    <div class="section-card">
        <h3>Campus Overview</h3>

        <p><strong>Total Clubs:</strong> @(Model?.Events?.Count ?? 0)</p>
        <p><strong>Total Events:</strong> @(Model?.Events?.Count ?? 0)</p>
        <p><strong>Total Attendance Records:</strong> @(Model?.Attendance?.Count ?? 0)</p>

        <hr />

        <h4>Recent Events</h4>
        @{
            var recentEvents = Model?.Events?.Take(5) ?? Enumerable.Empty<Club>();
        }

        <ul>
            @foreach (var evt in recentEvents)
            {
                <li>@evt.name — @evt.description</li>
            }
        </ul>
    </div>

</div>