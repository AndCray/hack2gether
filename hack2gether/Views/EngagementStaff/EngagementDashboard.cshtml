@model EngagementDashboardViewModel

@{
    ViewData["Title"] = "Student Engagement Dashboard";
}

<div class="container mt-4">

    <h1 class="mb-4">Student Engagement Dashboard</h1>

    <!-- Pending Event Approvals -->
    <section class="mb-5">
        <h2>Pending Event Approvals</h2>

        @if (Model.PendingEvents.Any())
        {
            <table class="table table-striped">
                <thead>
                    <tr>
                        <th>Event</th>
                        <th>Club</th>
                        <th>Date</th>
                        <th>Submitted By</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var ev in Model.PendingEvents)
                    {
                        <tr>
                            <td>@ev.Title</td>
                            <td>@ev.ClubName</td>
                            <td>@ev.Date.ToString("MMMM dd, yyyy")</td>
                            <td>@ev.SubmittedBy</td>
                            <td>
                                <form method="post" asp-action="ApproveEvent" class="d-inline">
                                    <input type="hidden" name="EventId" value="@ev.Id" />
                                    <button class="btn btn-success btn-sm">Approve</button>
                                </form>

                                <form method="post" asp-action="RejectEvent" class="d-inline">
                                    <input type="hidden" name="EventId" value="@ev.Id" />
                                    <button class="btn btn-danger btn-sm">Reject</button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        else
        {
            <p>No pending events at this time.</p>
        }

        <hr />
    </section>

    <!-- Campus Overview -->
    <section class="mb-5">
        <h2>Campus Events Overview</h2>

        <div class="row">
            @foreach (var ev in Model.AllEvents)
            {
                <div class="col-md-4 mb-3">
                    <div class="card shadow-sm">
                        <div class="card-body">
                            <h5 class="card-title">@ev.Title</h5>
                            <p class="card-text">
                                <strong>Club:</strong> @ev.ClubName<br />
                                <strong>Date:</strong> @ev.Date.ToString("MMMM dd, yyyy")<br />
                                <strong>Location:</strong> @ev.Location
                            </p>
                        </div>
                    </div>
                </div>
            }
        </div>

        <hr />
    </section>

    <!-- Notification Routing -->
    <section class="mb-5">
        <h2>Route Notifications</h2>

        <form method="post" asp-action="RouteNotification">
            <div class="mb-3">
                <label class="form-label">Message</label>
                <textarea name="Message" class="form-control" rows="3" required></textarea>
            </div>

            <div class="mb-3">
                <label class="form-label">Send To Department</label>
                <select name="Department" class="form-select" required>
                    <option value="">Select a department</option>
                    <option>Student Affairs</option>
                    <option>Campus Safety</option>
                    <option>Facilities</option>
                    <option>IT Services</option>
                    <option>Communications</option>
                </select>
            </div>

            <button type="submit" class="btn btn-primary">Send Notification</button>
        </form>
    </section>

</div>